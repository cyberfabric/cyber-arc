#!/usr/bin/env node

const { ensureResourcesManifest, getLocalResourcesManifestPath } = require("../src/resources");
const {
  ensureGlobalPromptRegistry,
  getPrompt,
  getPromptHelp,
  getPromptInfo,
  getPromptSource,
  getPromptTypeHelp,
  listActivePromptMetadata,
  listPromptTypeCatalog,
} = require("../src/prompts");
const { ensureGlobalScriptRegistry, getScriptHelp, listActiveScriptMetadata, runScript } = require("../src/scripts");
const { collectPromptText, delegatePrompt } = require("../src/delegates");
const { registerKitFolder } = require("../src/kits");
const { registerPrompts } = require("../src/register");
const { runWebServer } = require("../src/web-server");
const { callApi, getApiHelp, listActiveApiMetadata, getApiDefinition } = require("../src/apis");

function printUsage() {
  process.stderr.write("Usage: fabric prompt get <name>\n");
  process.stderr.write("   or: fabric prompt source <name>\n");
  process.stderr.write("   or: fabric prompt help <name>\n");
  process.stderr.write("   or: fabric prompt list [--verbose]\n");
  process.stderr.write("   or: fabric prompt types [--verbose]\n");
  process.stderr.write("   or: fabric delegate <claude|codex> <prompt>\n");
  process.stderr.write("   or: fabric prompt delegate <claude|codex> <name>\n");
  process.stderr.write("   or: fabric script run <id> [parameters...]\n");
  process.stderr.write("   or: fabric script help <id>\n");
  process.stderr.write("   or: fabric script list [--verbose]\n");
  process.stderr.write("   or: fabric api call <service> [-X METHOD] <path> [-H 'Name: Value']... [-d BODY | --json JSON]\n");
  process.stderr.write("   or: fabric api list [--verbose]\n");
  process.stderr.write("   or: fabric api help <service>\n");
  process.stderr.write("   or: fabric register [path] [--local] [--include-global]\n");
  process.stderr.write("   or: fabric init\n");
  process.stderr.write("   or: fabric web run [--port <port>]\n");
}

function writeResult(value) {
  if (value === undefined) {
    return;
  }

  const output = typeof value === "string" ? value : JSON.stringify(value);
  process.stdout.write(output.endsWith("\n") ? output : `${output}\n`);
}

function isVerboseFlag(value) {
  return value === "--verbose";
}

function sortById(entries) {
  return [...entries].sort((left, right) => left.id.localeCompare(right.id));
}

function formatPromptList(entries) {
  const sorted = sortById(entries);
  const lines = ["ID | Type | Name | Description"];

  for (const entry of sorted) {
    lines.push(`${entry.id} | ${entry.type} | ${entry.name} | ${entry.description || ""}`);
  }

  return lines.join("\n");
}

function formatScriptList(entries) {
  const sorted = sortById(entries);
  const lines = ["ID | Name | Description"];

  for (const entry of sorted) {
    lines.push(`${entry.id} | ${entry.name} | ${entry.description || ""}`);
  }

  return lines.join("\n");
}

function formatVerboseList(entries, formatter) {
  const sections = sortById(entries)
    .map((entry) => formatter(entry.id))
    .filter(Boolean);

  return sections.join("\n\n---\n\n");
}

function parseRegisterArguments(args) {
  if (args.length > 3) {
    return null;
  }

  let targetPath;
  let local = false;
  let includeGlobal = false;

  for (const arg of args) {
    if (arg === "--local") {
      if (local) {
        return null;
      }

      local = true;
      continue;
    }

    if (arg === "--include-global") {
      if (includeGlobal) {
        return null;
      }

      includeGlobal = true;
      continue;
    }

    if (targetPath !== undefined) {
      return null;
    }

    targetPath = arg;
  }

  return {
    targetPath,
    local,
    includeGlobal,
  };
}

function parseApiCallArguments(rest) {
  const [service, ...rawArgs] = rest;
  if (!service) return { error: "Missing API service name" };

  let method = "GET";
  let path;
  const headers = {};
  let body;
  let bodyFromJson = false;
  let i = 0;
  while (i < rawArgs.length) {
    const arg = rawArgs[i];
    if (arg === "-X" || arg === "--method") {
      const value = rawArgs[i + 1];
      if (!value) return { error: `Missing value for ${arg}` };
      method = value.toUpperCase();
      i += 2;
      continue;
    }
    if (arg === "-H") {
      const value = rawArgs[i + 1];
      if (!value) return { error: "Missing value for -H" };
      const splitIndex = value.indexOf(":");
      if (splitIndex === -1) return { error: `Malformed header (expected 'Name: Value'): ${value}` };
      const name = value.slice(0, splitIndex).trim();
      const headerValue = value.slice(splitIndex + 1).trim();
      if (!name) return { error: `Malformed header (empty name): ${value}` };
      headers[name] = headerValue;
      i += 2;
      continue;
    }
    if (arg === "-d" || arg === "--data") {
      if (body !== undefined) return { error: "Body supplied more than once (-d / --json)" };
      const value = rawArgs[i + 1];
      if (value === undefined) return { error: `Missing value for ${arg}` };
      body = value;
      i += 2;
      continue;
    }
    if (arg === "--json") {
      if (body !== undefined) return { error: "Body supplied more than once (-d / --json)" };
      const value = rawArgs[i + 1];
      if (value === undefined) return { error: "Missing value for --json" };
      body = value;
      bodyFromJson = true;
      i += 2;
      continue;
    }
    if (arg.startsWith("-")) {
      return { error: `Unknown flag: ${arg}` };
    }
    if (path !== undefined) {
      return { error: `Unexpected positional argument: ${arg}` };
    }
    path = arg;
    i += 1;
  }
  if (!path) return { error: "Missing request path" };

  if (bodyFromJson && !Object.keys(headers).some((h) => h.toLowerCase() === "content-type")) {
    headers["Content-Type"] = "application/json";
  }

  return { service, method, path, headers, body };
}

async function main(argv) {
  const [group, action, ...rest] = argv;

  if (group === "init" && action === undefined && rest.length === 0) {
    try {
      const manifestPath = getLocalResourcesManifestPath();
      ensureResourcesManifest(manifestPath, { promptFiles: [], scriptFiles: [] });
      process.stdout.write(`Initialized ${manifestPath}\n`);
      return 0;
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
  }

  try {
    ensureGlobalPromptRegistry();
    ensureGlobalScriptRegistry();
  } catch (error) {
    process.stderr.write(`${error.message}\n`);
    return 1;
  }

  if (group === "prompt" && action === "get" && rest.length === 1) {
    const [name] = rest;
    const prompt = getPrompt(name);

    if (!prompt) {
      process.stderr.write(`Unknown prompt: ${name}\n`);
      return 1;
    }

    process.stdout.write(`${prompt}\n`);
    return 0;
  }

  if (group === "prompt" && action === "source" && rest.length === 1) {
    const [name] = rest;
    const promptSource = getPromptSource(name);

    if (!promptSource) {
      process.stderr.write(`Unknown prompt: ${name}\n`);
      return 1;
    }

    process.stdout.write(`${promptSource}\n`);
    return 0;
  }

  if (group === "prompt" && action === "help" && rest.length === 1) {
    const [name] = rest;
    const help = getPromptHelp(name);

    if (help === undefined) {
      process.stderr.write(`Unknown prompt: ${name}\n`);
      return 1;
    }

    process.stdout.write(`${help}\n`);
    return 0;
  }

  if (group === "prompt" && action === "list" && (rest.length === 0 || (rest.length === 1 && isVerboseFlag(rest[0])))) {
    const verbose = isVerboseFlag(rest[0]);
    const prompts = listActivePromptMetadata();
    const output = verbose
      ? formatVerboseList(prompts, (id) => getPromptInfo(id))
      : formatPromptList(prompts);

    process.stdout.write(`${output}\n`);
    return 0;
  }

  if (group === "prompt" && action === "types" && (rest.length === 0 || (rest.length === 1 && isVerboseFlag(rest[0])))) {
    const verbose = isVerboseFlag(rest[0]);
    const catalog = listPromptTypeCatalog();

    if (verbose) {
      const sections = catalog
        .map((entry) => getPromptTypeHelp(entry.type))
        .filter(Boolean);

      process.stdout.write(`${sections.join("\n\n---\n\n")}\n`);
      return 0;
    }

    const lines = ["Type | Summary | When to use"];

    for (const entry of catalog) {
      lines.push(`${entry.type} | ${entry.summary} | ${entry.whenToUse}`);
    }

    process.stdout.write(`${lines.join("\n")}\n`);
    return 0;
  }

  if (group === "delegate" && rest.length >= 1) {
    const [provider, ...promptParts] = [action, ...rest];
    const prompt = collectPromptText(promptParts);

    if (!prompt) {
      process.stderr.write("Missing prompt text\n");
      return 1;
    }

    try {
      const result = delegatePrompt(provider, prompt);
      process.stdout.write(`${result}\n`);
      return 0;
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
  }

  if (group === "prompt" && action === "delegate" && rest.length === 2) {
    const [provider, name] = rest;
    const prompt = getPrompt(name);

    if (!prompt) {
      process.stderr.write(`Unknown prompt: ${name}\n`);
      return 1;
    }

    try {
      const result = delegatePrompt(provider, prompt);
      process.stdout.write(`${result}\n`);
      return 0;
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
  }

  if (group === "script" && action === "run" && rest.length >= 1) {
    const [id, ...scriptArgs] = rest;

    try {
      const execution = await runScript(id, scriptArgs);

      if (!execution) {
        process.stderr.write(`Unknown script: ${id}\n`);
        return 1;
      }

      writeResult(execution.result);
      return 0;
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
  }

  if (group === "script" && action === "help" && rest.length === 1) {
    const [id] = rest;

    try {
      const help = getScriptHelp(id);

      if (!help) {
        process.stderr.write(`Unknown script: ${id}\n`);
        return 1;
      }

      process.stdout.write(`${help}\n`);
      return 0;
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
  }

  if (group === "script" && action === "list" && (rest.length === 0 || (rest.length === 1 && isVerboseFlag(rest[0])))) {
    try {
      const verbose = isVerboseFlag(rest[0]);
      const scripts = listActiveScriptMetadata();
      const output = verbose
        ? formatVerboseList(scripts, (id) => getScriptHelp(id))
        : formatScriptList(scripts);

      process.stdout.write(`${output}\n`);
      return 0;
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
  }

  if (group === "api" && action === "call") {
    const parsed = parseApiCallArguments(rest);
    if (parsed.error) {
      process.stderr.write(`${parsed.error}\n`);
      printUsage();
      return 2;
    }

    try {
      const result = await callApi(parsed.service, {
        method: parsed.method,
        path: parsed.path,
        headers: parsed.headers,
        body: parsed.body,
      });

      const text = typeof result.body === "string"
        ? result.body
        : JSON.stringify(result.body);

      if (result.ok) {
        process.stdout.write(text);
        if (text.length > 0 && !text.endsWith("\n")) process.stdout.write("\n");
        return 0;
      }

      process.stderr.write(`HTTP ${result.status}\n`);
      if (text.length > 0) {
        process.stderr.write(text);
        if (!text.endsWith("\n")) process.stderr.write("\n");
      }
      return 1;
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
  }

  if (group === "api" && action === "list" && (rest.length === 0 || (rest.length === 1 && isVerboseFlag(rest[0])))) {
    const verbose = isVerboseFlag(rest[0]);
    let entries;
    try {
      entries = listActiveApiMetadata();
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }

    if (verbose) {
      const sections = entries
        .slice()
        .sort((a, b) => a.name.localeCompare(b.name))
        .map((entry) => getApiHelp(entry.name))
        .filter(Boolean);
      process.stdout.write(`${sections.join("\n\n---\n\n")}\n`);
      return 0;
    }

    const sorted = entries.slice().sort((a, b) => a.name.localeCompare(b.name));
    const lines = ["Name | Description | Base URL | Auth"];
    for (const entry of sorted) {
      lines.push(`${entry.name} | ${entry.description} | ${entry.baseUrl} | ${entry.authRef || "-"}`);
    }
    process.stdout.write(`${lines.join("\n")}\n`);
    return 0;
  }

  if (group === "api" && action === "help" && rest.length === 1) {
    const [name] = rest;
    let help;
    try {
      help = getApiHelp(name);
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
    if (help === undefined) {
      process.stderr.write(`Unknown API: ${name}\n`);
      return 1;
    }
    process.stdout.write(`${help}\n`);
    return 0;
  }

  if (group === "register") {
    const registerArguments = [action, ...rest].filter((value) => value !== undefined);
    const parsed = parseRegisterArguments(registerArguments);

    if (!parsed) {
      printUsage();
      return 1;
    }

    try {
      if (parsed.targetPath) {
        const result = registerKitFolder(parsed.targetPath, { local: parsed.local, includeGlobal: parsed.includeGlobal });
        process.stdout.write(`Registered resources from ${result.absoluteKitPath} into ${result.registryManifestPath} and generated ${result.registration.prompts.length} skills in ${result.registration.targets.length} skill roots\n`);
        return 0;
      }

      const result = registerPrompts({ local: parsed.local, includeGlobal: parsed.includeGlobal });
      process.stdout.write(`Registered ${result.prompts.length} prompts into ${result.targets.length} skill roots\n`);
      return 0;
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
  }

  if (group === "web" && action === "run") {
    const exitCode = await runWebServer(rest);
    return exitCode;
  }

  printUsage();
  return 1;
}

main(process.argv.slice(2))
  .then((exitCode) => {
    process.exit(exitCode);
  })
  .catch((error) => {
    process.stderr.write(`${error.message}\n`);
    process.exit(1);
  });
