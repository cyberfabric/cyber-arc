{
  "name": "@cyber-fabric/poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w packages/fabric-core run build && npm -w packages/fabric-adapter-claude -w packages/fabric-adapter-codex run build && npm -w packages/fabric-vscode run build",
    "clean": "npm run clean --workspaces",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint packages/*/src/**/*.ts",
    "demo": "tsx demo/run-demo.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {}
}
