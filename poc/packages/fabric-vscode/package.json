{
  "name": "@cyber-fabric/fabric-vscode",
  "displayName": "Cyber Fabric",
  "publisher": "cyber-fabric",
  "version": "0.1.0",
  "description": "VS Code extension for Cyber Fabric — chat panel, plan tree, and orchestrator integration",
  "type": "module",
  "main": "dist/extension.js",
  "types": "dist/extension.d.ts",
  "exports": {
    ".": {
      "types": "./dist/extension.d.ts",
      "import": "./dist/extension.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "echo 'No tests yet'"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onCommand:cyber-fabric.showStatus",
    "onCommand:cyber-fabric.runPipeline"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cyber-fabric.showStatus",
        "title": "Cyber Fabric: Show Status"
      },
      {
        "command": "cyber-fabric.runPipeline",
        "title": "Cyber Fabric: Run Pipeline"
      }
    ]
  },
  "dependencies": {
    "@cyber-fabric/fabric-core": "*"
  },
  "peerDependencies": {}
}
