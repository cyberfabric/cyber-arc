{
  "name": "@cyber-fabric/fabric-vscode",
  "displayName": "Cyber Fabric",
  "publisher": "cyber-fabric",
  "version": "0.1.0",
  "description": "VS Code extension for Cyber Fabric — chat panel, plan tree, and orchestrator integration",
  "type": "module",
  "main": "dist/extension.js",
  "types": "dist/extension.d.ts",
  "exports": {
    ".": {
      "types": "./dist/extension.d.ts",
      "import": "./dist/extension.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "echo 'No tests configured' && exit 1"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onCommand:cyber-fabric.showStatus",
    "onCommand:cyber-fabric.runPipeline",
    "onCommand:cyber-fabric.openChat",
    "onView:cyberFabric.planTree",
    "onView:cyberFabric.delegationStatus"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cyber-fabric.showStatus",
        "title": "Cyber Fabric: Show Status"
      },
      {
        "command": "cyber-fabric.runPipeline",
        "title": "Cyber Fabric: Run Pipeline"
      },
      {
        "command": "cyber-fabric.openChat",
        "title": "Cyber Fabric: Open Chat"
      },
      {
        "command": "cyber-fabric.openPhase",
        "title": "Cyber Fabric: Open Phase Details"
      },
      {
        "command": "cyber-fabric.cancelDelegation",
        "title": "Cyber Fabric: Cancel Delegation",
        "icon": "$(close)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cyberFabric",
          "title": "Cyber Fabric",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "views": {
      "cyberFabric": [
        {
          "id": "cyberFabric.planTree",
          "name": "Plan Phases"
        },
        {
          "id": "cyberFabric.delegationStatus",
          "name": "Delegation Status"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "cyber-fabric.cancelDelegation",
          "when": "viewItem == activeDelegation",
          "group": "inline"
        }
      ]
    }
  },
  "dependencies": {
    "@cyber-fabric/fabric-core": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  },
  "peerDependencies": {}
}
